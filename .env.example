# Supabase 연결 정보 (이 파일을 복사해 .env.local 로 만들고 값을 채우세요)
# cp .env.example .env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# 마케팅 대시보드 전용 Supabase 프로젝트 (세일즈와 분리)
NEXT_PUBLIC_MKT_SUPABASE_URL=https://YOUR-MARKETING-PROJECT.supabase.co
NEXT_PUBLIC_MKT_SUPABASE_ANON_KEY=YOUR-MARKETING-ANON-KEY

# 김은아 루틴 페이지 전용 Supabase 프로젝트 (세일즈·마케팅과 분리)
NEXT_PUBLIC_RTN_SUPABASE_URL=https://YOUR-ROUTINE-PROJECT.supabase.co
NEXT_PUBLIC_RTN_SUPABASE_ANON_KEY=YOUR-ROUTINE-ANON-KEY

# 사이트 접속 비밀번호 (서버에만 저장됨)
APP_PASSWORD=set-a-password-here
